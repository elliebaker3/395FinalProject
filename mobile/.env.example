# Copy to ".env" in this folder (same directory as app.config.js).
# Expo loads these when you run `npx expo start`.
#
# Web = Google Cloud → Credentials → OAuth client → Application type "Web application".
# Expo Go only needs the Web client ID (same ID is used for ios/android slots in code).
#
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
#
# iOS = separate OAuth client → Application type "iOS". Required for expo-dev-client /
# standalone builds (native redirect). Must NOT be the same string as the Web client ID.
#
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
