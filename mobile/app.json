{
  "expo": {
    "name": "CallWizard",
    "slug": "callwizard",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "callwizard",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.callwizard.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.callwizard.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://callwizard-api.onrender.com",
      "eas": {
        "projectId": "e0f0012c-98c0-4807-adcd-5f31a952ecfa"
      }
    },
    "owner": "efbaker"
  }
}
