PORT=3001
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Optional: path to Firebase service account JSON for FCM (server sends pushes)
GOOGLE_APPLICATION_CREDENTIALS=
# Used for pgcrypto encryption of Google OAuth tokens stored in DB.
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-strong-random-secret
# Optional if backend needs to refresh Google OAuth access tokens.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
